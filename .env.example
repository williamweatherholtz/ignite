# Ignite config. Copy this file to `.env` (docker compose reads it automatically), then edit.
#
# THE ONE THING TO SET: the host folder that CONTAINS your vault subfolders.
# Each immediate subdirectory becomes a vault (e.g. VAULTS_DIR=C:\vaults with C:\vaults\Games,
# C:\vaults\Work -> two vaults "Games" and "Work"). It maps to /vaults inside the container.
VAULTS_DIR=C:\vaults

# --- optional ---
RUST_LOG=debug                    # log level: error | warn | info | debug | trace
# OBSIDIAN_VERSION=1.12.7
# IGNITE_DOMAIN=notes.example.com  # (stack only) real domain -> auto HTTPS; unset = localhost self-signed

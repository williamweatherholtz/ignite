        part storyBootstrapVaultDoDR9 : TestResult { :>> id = "5e4ca9d1-c744-4667-a879-13c62ba93f7d"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "9f29e89"; :>> judgedAt = "2026-07-02"; :>> judgedBy = "claudeOpus"; }

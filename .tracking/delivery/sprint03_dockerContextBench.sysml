    part dockerContextBenchCloseOutGateR1 : TestResult { :>> id = "5e370489-5d01-464b-a146-14515df37d1c"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "8fc3505"; :>> judgedAt = "2026-06-30"; :>> judgedBy = "ai"; }
    verification dockerContextBenchRetroGate : Test { :>> id = "62eeaffd-9120-40b5-acf7-d6acc2cf5bec"; :>> title = "Sprint 3 retro gate (autonomous, D0049)"; :>> createdAt = "2026-06-30"; :>> createdBy = "ai"; :>> method = VerificationMethod::analyze; :>> procedureText = "Autonomous retro (D0049). WELL: pushing the comparison into Ignis's ACTUAL Docker context turned a confounded headline into a defensible end-to-end story - per-request tree load drops from tens of seconds (Ignis, every request) to ~2ms (Ignite, warm after a one-time startup), with Docker's bind mount as the dominant raw cost. AVOIDABLE-ISSUE SCAN -> issue005 (Docker cold mitigation + deployment guidance). LESSON: the warm-index architecture's value is LARGEST exactly where the filesystem is slow (Docker) - it amortizes one cold walk across all requests, which is the structural advantage over Ignis's per-request re-walk. Estimate 2pt held."; }
    part dockerContextBenchRetroGateR1 : TestResult { :>> id = "cf6ae332-5295-442a-9866-183115868bf7"; :>> outcome = VerdictKind::pass; :>> judgedAgainst = "8fc3505"; :>> judgedAt = "2026-06-30"; :>> judgedBy = "ai"; }
